# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key
KAKAO_REST_API_KEY=your_kakao_rest_api_key
TOUR_API_KEY=your_tour_api_service_key

# Database (Supabase - Session pooler 포트 5432)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres
# 로컬 Docker DB 사용 시:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pedalro

# App
APP_ENV=development
DEBUG=true
